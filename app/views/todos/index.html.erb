<p style="color: green"><%= notice %></p>

<% content_for :title, "Todos" %>

<h1>Todos</h1>

<%= form_with url: todos_path, method: :get, local: true do |f| %>
  <%= f.select :category,
        Todo::CATEGORIES,
        { include_blank: "All", selected: @selected_category },
        { id: "category_filter" } %>
  <%= f.submit "Filter" %>
<% end %>

<div id="todos">
  <% @todos.each do |todo| %>
    <%= render todo %>
    <p>
      <%= link_to "Show this todo", todo %>
    </p>
  <% end %>
</div>

<%= link_to "New todo", new_todo_path %>
